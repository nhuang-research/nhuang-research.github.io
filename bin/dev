#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
HOST="${JEKYLL_HOST:-127.0.0.1}"
PORT="${JEKYLL_PORT:-4000}"

export PATH="$ROOT_DIR/.local/ruby-3.3.10/bin:$PATH"

cd "$ROOT_DIR"
exec bundle exec jekyll serve \
  --config _config.yml,_config.dev.yml \
  --host "$HOST" \
  --port "$PORT"
